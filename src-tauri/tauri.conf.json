{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "z-switch",
  "version": "0.1.0",
  "identifier": "ai.ztest.zswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "z-switch",
        "width": 900,
        "height": 640,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/zsw.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/zsw.ico",
        "uninstallerIcon": "icons/zsw.ico"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["zswitch"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/ZtestAi/z-switch/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_NEW_TAURI_PUBKEY"
    }
  }
}
